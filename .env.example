# --- SmartSymptom AI Environment Template ---

# 1. Google Gemini API (For Medical Refinement)
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Kaggle Custom Model API (Ngrok URL)
# Example: https://abcd-123-456.ngrok-free.dev
NEXT_PUBLIC_KAGGLE_API_URL=your_ngrok_url_here

# 3. Google Maps Platform
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# 4. Database (Supabase / PostgreSQL)
DATABASE_URL="postgresql://postgres:[password]@[host]:6543/postgres"
DIRECT_URL="postgresql://postgres:[password]@[host]:5432/postgres"

# 5. NextAuth Configuration
NEXTAUTH_SECRET=your_random_secret_string
NEXTAUTH_URL=http://localhost:3000

# 6. Supabase Public Keys
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# 7. Firebase (Optional for storage/analytics)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="your_private_key"
