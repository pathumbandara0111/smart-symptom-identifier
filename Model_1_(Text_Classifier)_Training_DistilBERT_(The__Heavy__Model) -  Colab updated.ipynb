# ==========================================
# 0. SETUP
# ==========================================
import os
import torch
import pandas as pd
import joblib

from huggingface_hub import login
from transformers import (
    DistilBertTokenizer,
    DistilBertForSequenceClassification,
    Trainer,
    TrainingArguments
)
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import LabelEncoder
from sklearn.metrics import accuracy_score

# ================= CONFIG =================
HF_TOKEN = "YOUR_HF_TOKEN"
DATA_PATH = "Symptom2Disease.csv"
SAVE_PATH = "./saved_models"

# Login to HuggingFace
login(token=HF_TOKEN)

# ==========================================
# 1. LOAD DATA
# ==========================================
df = pd.read_csv(DATA_PATH)

if 'Unnamed: 0' in df.columns:
    df = df.drop('Unnamed: 0', axis=1)

# Encode labels
le = LabelEncoder()
df['label_num'] = le.fit_transform(df['label'])

os.makedirs(SAVE_PATH, exist_ok=True)
joblib.dump(le, os.path.join(SAVE_PATH, 'label_encoder.pkl'))

# ==========================================
# 2. TOKENIZER
# ==========================================
tokenizer = DistilBertTokenizer.from_pretrained('distilbert-base-uncased')

class SymptomDataset(torch.utils.data.Dataset):
    def __init__(self, encodings, labels):
        self.encodings = encodings
        self.labels = labels

    def __getitem__(self, idx):
        return {
            key: torch.tensor(val[idx]) for key, val in self.encodings.items()
        } | {
            'labels': torch.tensor(self.labels[idx])
        }

    def __len__(self):
        return len(self.labels)

def compute_metrics(pred):
    labels = pred.label_ids
    preds = pred.predictions.argmax(-1)
    return {'accuracy': accuracy_score(labels, preds)}

# ==========================================
# 3. TRAIN LOOP
# ==========================================
def train_model():
    for i in range(1, 6):
        print(f"\n🚀 Starting ITERATION {i}/5")

        version_path = os.path.join(SAVE_PATH, f'v{i}')
        os.makedirs(version_path, exist_ok=True)

        train_texts, val_texts, train_labels, val_labels = train_test_split(
            df['text'].tolist(),
            df['label_num'].tolist(),
            test_size=0.15,
            shuffle=True
        )

        train_encodings = tokenizer(train_texts, truncation=True, padding=True, max_length=128)
        val_encodings = tokenizer(val_texts, truncation=True, padding=True, max_length=128)

        train_dataset = SymptomDataset(train_encodings, train_labels)
        val_dataset = SymptomDataset(val_encodings, val_labels)

        model = DistilBertForSequenceClassification.from_pretrained(
            'distilbert-base-uncased',
            num_labels=len(le.classes_)
        )

        training_args = TrainingArguments(
            output_dir=f'./results_v{i}',
            num_train_epochs=5,
            per_device_train_batch_size=16,
            eval_strategy="epoch",
            save_strategy="no",
            logging_steps=50,
            report_to="none"
        )

        trainer = Trainer(
            model=model,
            args=training_args,
            train_dataset=train_dataset,
            eval_dataset=val_dataset,
            compute_metrics=compute_metrics
        )

        trainer.train()

        print(f"✅ Saving model v{i}")
        model.save_pretrained(version_path)
        tokenizer.save_pretrained(version_path)

    print("\n🌟 Training Complete!")

# ==========================================
# 4. RUN
# ==========================================
if __name__ == "__main__":
    train_model()
